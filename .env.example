# ============================================================
# Configuração de ambiente — Tio Preto Barbearia
# Copie este arquivo para `.env` e preencha os valores reais.
# O arquivo `.env` NÃO é versionado (ver .gitignore).
# ============================================================

# --- Banco de dados (MySQL/MariaDB) ---
# No XAMPP local, deixe os valores padrão abaixo (ou omita estas linhas).
# Em produção (ex.: Railway), defina estas variáveis no painel do serviço
# apontando para o host/porta internos do banco.
DB_HOST=localhost
DB_PORT=3307
DB_NAME=tiopretobarbearia
DB_USER=root
DB_PASSWORD=

# --- Envio de e-mail (SMTP via PHPMailer) ---
# Nome exibido como remetente das mensagens
MAIL_FROM_NAME="Tio Preto Barbearia"
# E-mail remetente (deve bater com a conta SMTP na maioria dos provedores)
MAIL_FROM_EMAIL=nao-responda@tiopretobarbearia.com.br

# Servidor SMTP
MAIL_HOST=smtp.exemplo.com
MAIL_PORT=587
# Criptografia: tls (porta 587) ou ssl (porta 465)
MAIL_ENCRYPTION=tls
MAIL_USERNAME=
MAIL_PASSWORD=

# 1 = liga o modo de depuração do SMTP no log do PHP; 0 = desligado
MAIL_DEBUG=0

# --- Integração WhatsApp (API r4dev) ---
# Endpoint da instância e token de acesso (obtidos no painel do provedor).
WHATSAPP_ENDPOINT=
WHATSAPP_TOKEN=
