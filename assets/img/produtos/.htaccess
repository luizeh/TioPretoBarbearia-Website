# Diretório de uploads: apenas arquivos estáticos.
# Impede execução de qualquer script no servidor (defesa contra upload malicioso).

# Desliga o motor PHP neste diretório (mod_php).
<IfModule mod_php.c>
    php_admin_flag engine off
</IfModule>
<IfModule mod_php7.c>
    php_admin_flag engine off
</IfModule>
<IfModule mod_php5.c>
    php_admin_flag engine off
</IfModule>

# Nega acesso a extensões executáveis, caso o motor não seja desligado acima.
<FilesMatch "(?i)\.(php|php3|php4|php5|php7|phtml|pht|phar|cgi|pl|py|sh|asp|aspx|jsp)$">
    Require all denied
</FilesMatch>
